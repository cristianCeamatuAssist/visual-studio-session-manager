{
  "name": "vscode-session-manager",
  "displayName": "Visual Studio Session Manager",
  "description": "Monitor and switch between VS Code projects with Claude Code CLI session status indicators",
  "version": "0.6.0",
  "publisher": "cristianCeamatuAssist",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cristianCeamatuAssist/visual-studio-session-manager"
  },
  "homepage": "https://github.com/cristianCeamatuAssist/visual-studio-session-manager#readme",
  "bugs": {
    "url": "https://github.com/cristianCeamatuAssist/visual-studio-session-manager/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-sessions",
          "title": "Claude Sessions",
          "icon": "resources/claude-sessions.svg"
        }
      ]
    },
    "views": {
      "claude-sessions": [
        {
          "id": "claudeSessionsProjects",
          "name": "Projects"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSessions.addProject",
        "title": "Open New Project",
        "icon": "$(add)"
      },
      {
        "command": "claudeSessions.refreshProjects",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSessions.openProject",
        "title": "Open Project"
      },
      {
        "command": "claudeSessions.openProjectNewWindow",
        "title": "Open in New Window",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "claudeSessions.openTerminal",
        "title": "Open Terminal Here",
        "icon": "$(terminal)"
      },
      {
        "command": "claudeSessions.installHooks",
        "title": "Claude Sessions: Install Status Hooks"
      },
      {
        "command": "claudeSessions.uninstallHooks",
        "title": "Claude Sessions: Uninstall Status Hooks"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSessions.addProject",
          "when": "view == claudeSessionsProjects",
          "group": "navigation@1"
        },
        {
          "command": "claudeSessions.refreshProjects",
          "when": "view == claudeSessionsProjects",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeSessions.openProjectNewWindow",
          "when": "view == claudeSessionsProjects && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "claudeSessions.openTerminal",
          "when": "view == claudeSessionsProjects && viewItem == project",
          "group": "inline@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeSessionsProjects",
        "contents": "No VS Code windows detected.\n[Open a Project](command:claudeSessions.addProject)"
      }
    ],
    "configuration": {
      "title": "Claude Sessions",
      "properties": {
        "claudeSessions.pollingInterval": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "description": "How often to check Claude session status (ms)"
        },
        "claudeSessions.cpuThreshold": {
          "type": "number",
          "default": 5,
          "description": "CPU% above which a Claude session is considered 'active' vs 'waiting'"
        },
        "claudeSessions.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Claude session count in the status bar"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "npx @vscode/vsce package --no-dependencies",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
